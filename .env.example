# ─── PNP Arena Configuration ─────────────────────────────────────────────────

# Server
PORT=3000
CORS_ORIGIN=*

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Solana RPC endpoint (used for on-chain verification)
# Mainnet
RPC_URL=https://api.mainnet-beta.solana.com
# Or use a premium RPC for reliability:
# RPC_URL=https://your-helius-or-quicknode-url.com

# $PNP Token Mint (do not change)
